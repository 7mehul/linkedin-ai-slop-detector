{
  "manifest_version": 3,
  "name": "SlopShield",
  "version": "1.0.1",
  "description": "Redacts LinkedIn slop with a censor bar and a snarky stamp. Detects the dialect, not the AI. Nothing leaves your browser.",
  "minimum_chrome_version": "120",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SlopShield",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "content/wordlists.js",
        "content/signals.js",
        "content/scorer.js",
        "content/extractor.js",
        "content/redactor.js",
        "content/content.js"
      ],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
